{
  "name": "@pihanga2/ivcap",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "author": "max.ott@data61.csiro.au",
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.js",
  "keywords": [
    "pihanga",
    "module",
    "library"
  ],
  "scripts": {
    "docs": "yarn typedoc",
    "build": "tsc --build && typedoc",
    "build:watch": "tsc --build --watch && typedoc",
    "prettier": "prettier --write .",
    "preview": "vite preview",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@auth0/auth0-spa-js": "^2.1.3",
    "js-yaml": "^4.1.0",
    "uuid": "^10.0.0"
  },
  "peerDependencies": {
    "@pihanga2/core": "^0.3.0"
  },
  "devDependencies": {
    "@microsoft/tsdoc": "^0.14.1",
    "@types/js-yaml": "^4.0.9",
    "@types/luxon": "^2.3.2",
    "@types/node": "^17.0.35",
    "@types/uuid": "^10.0.0",
    "c8": "^7.11.3",
    "eslint": "^8.0.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-prettier": "^4.2.1",
    "prettier": "^2.7.1",
    "prettier-config-nick": "^1.0.2",
    "rollup-plugin-typescript-paths": "^1.4.0",
    "rollup-plugin-visualizer": "^5.10.0",
    "tslib": "^2.6.2",
    "typedoc": "^0.25.4",
    "typescript": "^5.0.2",
    "vite": "^5.0.4",
    "vite-plugin-progress": "^0.0.7",
    "vitest": "^0.34.6"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "plugins": [
      "prettier"
    ],
    "rules": {
      "prettier/prettier": "error",
      "react/jsx-no-target-blank": "off"
    }
  },
  "prettier": "prettier-config-nick"
}